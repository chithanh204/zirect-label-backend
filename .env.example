# ============================================
# Zirect Label Backend - Environment Variables
# ============================================

# DATABASE CONFIGURATION
# ─────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# Production: PostgreSQL
# DATABASE_URL="postgresql://username:password@localhost:5432/zirect_label"

# Supabase Cloud
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres"

# Railway Cloud
# DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:[PORT]/[DATABASE]"

# AWS RDS
# DATABASE_URL="postgresql://admin:password@zirect-db.xxx.us-east-1.rds.amazonaws.com:5432/zirect_label"


# SERVER CONFIGURATION
# ─────────────────────────────────────────
PORT=5000
NODE_ENV=production
FRONTEND_URL=https://yourdomain.com


# JWT CONFIGURATION
# ─────────────────────────────────────────
# Generate secure key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=generate-a-strong-random-key-at-least-32-characters-long
JWT_EXPIRES_IN=7d


# API CONFIGURATION (Optional)
# ─────────────────────────────────────────
API_BASE_URL=https://api.yourdomain.com