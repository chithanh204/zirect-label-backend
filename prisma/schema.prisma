// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  type      UserType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artist    Artist?
  
  @@map("users")
}

enum UserType {
  artist
  admin
}

model Artist {
  id             String   @id @default(cuid())
  userId         String   @unique
  name           String
  email          String   @unique
  bio            String?
  avatar         String?
  website        String?
  paymentMethod  String?
  currency       String?
  bankAccount    String?
  paymentVerificationStatus PaymentStatus @default(unverified)
  followers      Int      @default(0)
  totalStreams   Int      @default(0)
  totalRevenue   Float    @default(0)
  balance        Float    @default(0)
  totalPaid      Float    @default(0)
  status         ArtistStatus @default(active)
  joinedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  paypalAccount  String?
  composerName   String?
  isActive       Boolean  @default(true)
  isAdmin        Boolean  @default(false)

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  albums          Album[]
  analytics       Analytics[]
  collaborations  AlbumCollaborator[]
  revenueSplits   RevenueSplit[]
  paymentLogs     PaymentLog[]

  @@map("artists")
}

enum ArtistStatus {
  active
  pending
  blocked
}

enum PaymentStatus {
  unverified
  pending
  verified
}

model Album {
  id               String    @id @default(cuid())
  title            String
  artistId         String
  artistName       String
  albumId          String?
  youtubeId        String?
  releaseDate      DateTime?
  coverArt         String?
  status           AlbumStatus @default(draft)
  totalStreams     Int       @default(0)
  revenue          Float     @default(0)
  upc              String?
  rejectionReason  String?
  
  // Album metadata
  displayArtist    String?
  primaryArtists   String?
  featuringArtists String?
  pYear            Int?
  cYear            Int?
  pLine            String?
  cLine            String?
  genre            String?
  subgenre         String?
  
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  artist           Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tracks           Track[]
  analytics        Analytics[]
  collaborators    AlbumCollaborator[]
  revenueSplits    RevenueSplit[]
  platformRevenues PlatformRevenue[]
  platformPayments PlatformPayment[]
  paymentLogDetails PaymentLogDetail[]

  @@map("albums")
}

enum AlbumStatus {
  draft
  submitted
  approved
  distributed
  rejected
}

model Track {
  id        String   @id @default(cuid())
  albumId   String
  title     String
  isrc      String?
  featuring String?
  streams   Int      @default(0)
  revenue   Float    @default(0)
  
  // Track metadata
  mixTitle        String?
  primaryArtists  String?
  remixingArtists String?
  composers String?
  lyricists String?
  language  String?
  pYear     Int?
  cYear     Int?
  pLine     String?
  cLine     String?
  genre     String?
  subgenre  String?
  hasExplicitContent Boolean @default(false)
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  platforms TrackPlatform[]

  @@map("tracks")
}

model TrackPlatform {
  id            String   @id @default(cuid())
  trackId       String
  platform      String   // "spotify", "youtube_music"
  streams       Int      @default(0)
  copyrightFlag Boolean  @default(false)
  url           String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([trackId, platform])
  @@map("track_platforms")
}

model AlbumCollaborator {
  id        String   @id @default(cuid())
  albumId   String
  artistId  String
  role      String   @default("featured") // "featured", "producer", "songwriter"
  createdAt DateTime @default(now())

  album  Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([albumId, artistId])
  @@map("album_collaborators")
}

model PlatformRevenue {
  id           String   @id @default(cuid())
  albumId      String
  platform     String   // "spotify", "youtube_music"
  totalRevenue Float    @default(0)
  updatedAt    DateTime @updatedAt

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@unique([albumId, platform])
  @@map("platform_revenues")
}

model PlatformPayment {
  id        String   @id @default(cuid())
  albumId   String
  platform  String   // "spotify", "youtube_music"
  amount    Float
  note      String?
  paidAt    DateTime @default(now())

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@map("platform_payments")
}

model RevenueSplit {
  id          String   @id @default(cuid())
  albumId     String
  artistId    String
  percentage  Float    // 0-100
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  album  Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)
  artist Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([albumId, artistId])
  @@map("revenue_splits")
}

model Analytics {
  id        String   @id @default(cuid())
  artistId  String
  albumId   String?
  date      DateTime
  streams   Int      @default(0)
  revenue   Float    @default(0)
  platform  String   // spotify, youtube_music, etc.
  region    String?  // US, UK, DE, FR, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  album     Album?   @relation(fields: [albumId], references: [id], onDelete: SetNull)

  @@map("analytics")
  @@index([artistId])
  @@index([albumId])
  @@index([date])
}

model HomePage {
  id          String   @id @default("singleton")
  logoUrl     String?
  title       String?
  description String?
  updatedAt   DateTime @updatedAt

  @@map("homepage_configs")
}

model FeaturedRelease {
  id          String   @id @default(cuid())
  trackName   String
  artistNames String
  spotifyLink String?
  youtubeLink String?
  coverArt    String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("featured_releases")
}

model ContractSubmission {
  id         String   @id @default(cuid())
  artistName String
  email      String
  subject    String
  message    String
  demoLink   String?
  status     String   @default("new") // "new", "reviewed"
  createdAt  DateTime @default(now())

  @@map("contract_submissions")
}

model PaymentLog {
  id            String   @id @default(cuid())
  artistId      String
  amount        Float
  paypalAccount String
  transactionId String
  receiptUrl    String?
  note          String?
  paidAt        DateTime @default(now())

  artist        Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  details       PaymentLogDetail[]

  @@map("payment_logs")
}

model PaymentLogDetail {
  id           String     @id @default(cuid())
  paymentLogId String
  albumId      String
  amount       Float

  paymentLog   PaymentLog @relation(fields: [paymentLogId], references: [id], onDelete: Cascade)
  album        Album      @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@map("payment_log_details")
}

