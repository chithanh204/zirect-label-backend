// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  type      UserType
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artist    Artist?
  
  @@map("users")
}

enum UserType {
  artist
  admin
}

model Artist {
  id             String   @id @default(cuid())
  userId         String   @unique
  name           String
  email          String   @unique
  bio            String?
  avatar         String?
  followers      Int      @default(0)
  totalStreams   Int      @default(0)
  totalRevenue   Float    @default(0)
  status         ArtistStatus @default(active)
  joinedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  albums     Album[]
  analytics  Analytics[]

  @@map("artists")
}

enum ArtistStatus {
  active
  pending
  blocked
}

model Album {
  id               String    @id @default(cuid())
  title            String
  artistId         String
  artistName       String
  releaseDate      DateTime?
  coverArt         String?
  status           AlbumStatus @default(draft)
  totalStreams     Int       @default(0)
  revenue          Float     @default(0)
  upc              String?
  rejectionReason  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  artist    Artist    @relation(fields: [artistId], references: [id], onDelete: Cascade)
  tracks    Track[]
  analytics Analytics[]

  @@map("albums")
}

enum AlbumStatus {
  draft
  submitted
  approved
  delivering
  distributed
  rejected
}

model Track {
  id        String   @id @default(cuid())
  albumId   String
  title     String
  duration  Int      // seconds
  isrc      String?
  featuring String?
  streams   Int      @default(0)
  revenue   Float    @default(0)
  position  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  album     Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@map("tracks")
}

model Analytics {
  id        String   @id @default(cuid())
  artistId  String
  albumId   String?
  date      DateTime
  streams   Int      @default(0)
  revenue   Float    @default(0)
  platform  String   // spotify, apple_music, youtube, etc.
  region    String?  // US, UK, DE, FR, etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  artist    Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  album     Album?   @relation(fields: [albumId], references: [id], onDelete: SetNull)

  @@map("analytics")
  @@index([artistId])
  @@index([albumId])
  @@index([date])
}
